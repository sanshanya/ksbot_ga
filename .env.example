# GenericAgent checkout
GA_ROOT=./vendor/GenericAgent

# WPS 365 application
WPS365_API_BASE=https://openapi.wps.cn
WPS365_CLIENT_ID=
WPS365_CLIENT_SECRET=
GA_WPS_CALLBACK_SECRET=change-me

# Runtime
GA_RUNTIME_ROOT=./runtime
GA_WPS_CALLBACK_HOST=127.0.0.1
GA_WPS_CALLBACK_PORT=23883
GA_WPS_MAX_WORKERS=8
GA_MAX_TURNS=80
GA_WPS_RECENT_HISTORY_MESSAGES=30
GA_WPS_SEEN_EVENTS_LIMIT=2048
GA_WPS_APPROVAL_TIMEOUT_SECONDS=300
GA_WPS_LAUNCH_BRIDGE=true

# Cluster inventory: the authoritative mapping from kube context to environment.
GA_CLUSTER_CONFIG=./config/clusters.yaml
GA_KUBECTL_PROBE_TIMEOUT_SECONDS=5

# AI Gate model config. By default the Gate reads the model config from
# vendor/GenericAgent/mykey.py via GA_GATE_CONFIG_KEY, so you do not need to
# duplicate model settings here. Set explicit GA_GATE_BASE_URL/MODEL/API_KEY
# only when the Gate should use a different endpoint than the main agent.
GA_GATE_CONFIG_KEY=native_oai_config
# GA_GATE_BASE_URL=
# GA_GATE_API_KEY=
# GA_GATE_MODEL=
GA_GATE_TIMEOUT_SECONDS=30

# Optional only for scripts/fetch_ga.py; CLI --proxy takes precedence.
# GA_FETCH_PROXY=http://127.0.0.1:10090
